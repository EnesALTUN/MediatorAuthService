{
  "JwtTokenOption": {
    "Audience": [ "mediator.auth" ],
    "Issuer": "mediator.auth",
    "AccessTokenExpiration": 3,
    "RefreshTokenExpiration": 30,
    "SecurityKey": ""
  },
  "MediatR": {
    "LicenseKey": ""
  },
  "ElasticSearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "mediator-auth-service-{0:yyyy.MM.dd}",
    "Username": "",
    "Password": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        // If you wish to log database queries, you can enable the following details. However, this may affect performance, so use it with caution.
        //"Microsoft.EntityFrameworkCore.Database.Command": "Information", 
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
